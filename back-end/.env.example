# Environment Example
NODE_ENV=development
PORT=3001

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/autodiag?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=
EMBEDDING_MODEL=

# CORS
CORS_ORIGIN=http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
